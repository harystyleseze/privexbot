{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@privexbot/source"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web-frontend/src/*"],
      "@privexbot/shared-utils": ["libs/shared-utils/src/index.ts"]
    },
    "rootDir": ".",
    "jsx": "react-jsx"
  }
}
