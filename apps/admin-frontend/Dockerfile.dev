# Development Dockerfile for admin-frontend
FROM node:22-alpine

WORKDIR /app

# Copy root configuration files
COPY package.json package-lock.json ./
COPY nx.json tsconfig.base.json ./

# Install all dependencies (including dev dependencies)
RUN npm ci

# Copy app-specific configs
COPY apps/admin-frontend/package.json ./apps/admin-frontend/
COPY apps/admin-frontend/project.json ./apps/admin-frontend/
COPY apps/admin-frontend/tsconfig*.json ./apps/admin-frontend/
COPY apps/admin-frontend/vite.config.ts ./apps/admin-frontend/
COPY apps/admin-frontend/tailwind.config.js ./apps/admin-frontend/
COPY apps/admin-frontend/postcss.config.js ./apps/admin-frontend/
COPY apps/admin-frontend/components.json ./apps/admin-frontend/

# Copy libs (can be mounted as volume for live reload)
COPY libs ./libs

# Copy source code (will be mounted as volume for live reload)
COPY apps/admin-frontend/src ./apps/admin-frontend/src
COPY apps/admin-frontend/public ./apps/admin-frontend/public
COPY apps/admin-frontend/index.html ./apps/admin-frontend/

# Expose development port
EXPOSE 3001

# Default command (can be overridden in docker-compose)
CMD ["npx", "nx", "serve", "admin-frontend", "--host", "0.0.0.0", "--port", "3001"]