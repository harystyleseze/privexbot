# Development Dockerfile for web-frontend
FROM node:22-alpine

WORKDIR /app

# Copy root configuration files
COPY package.json package-lock.json ./
COPY nx.json tsconfig.base.json ./

# Install all dependencies (including dev dependencies)
RUN npm ci

# Copy app-specific configs
COPY apps/web-frontend/package.json ./apps/web-frontend/
COPY apps/web-frontend/project.json ./apps/web-frontend/
COPY apps/web-frontend/tsconfig*.json ./apps/web-frontend/
COPY apps/web-frontend/vite.config.ts ./apps/web-frontend/
COPY apps/web-frontend/tailwind.config.js ./apps/web-frontend/
COPY apps/web-frontend/postcss.config.js ./apps/web-frontend/
COPY apps/web-frontend/components.json ./apps/web-frontend/

# Copy libs (can be mounted as volume for live reload)
COPY libs ./libs

# Copy source code (will be mounted as volume for live reload)
COPY apps/web-frontend/src ./apps/web-frontend/src
COPY apps/web-frontend/public ./apps/web-frontend/public
COPY apps/web-frontend/index.html ./apps/web-frontend/

# Expose development port
EXPOSE 3000

# Default command (can be overridden in docker-compose)
CMD ["npx", "nx", "serve", "web-frontend", "--host", "0.0.0.0"]